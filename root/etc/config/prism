config prism 'global'
	option enabled '0'
	option config_path '/var/etc/prism/sing-box.json'
	option log_level 'warn'
	option ruleset_delivery 'github'
	option ruleset_download_detour 'direct'
	option country_provider 'sagernet'

config prism 'inbounds'
	option mode 'tproxy'
	option tproxy_port '7895'
	option inet6 '0'
	option tun_address '172.19.0.1/30'
	option tun_mtu '9000'
	option tun_stack 'system'
	option tun_auto_route '1'
	option mixed_listen '127.0.0.1'
	option mixed_port '2080'

config prism 'dns'
	option strategy ''
	option managed_dns '1'
	option local_server 'wan'
	option remote_server ''
	option fakeip_enabled '0'
	option fakeip_range_v4 '198.18.0.0/15'
	option fakeip_range_v6 'fc00::/18'

config prism 'routing'
