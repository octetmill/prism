-- Copyright (C) 2026 OctetMill
--
-- Background runner for the Nodes panel's latency tests (per-row Test,
-- "Test all", and the per-subscription batch).
--
-- luci.prism's test_all_start RPC forks this script (no stdin/stdout/stderr
-- attached) so it survives the parent rpcd worker's exit. The script then:
--
--   1. Builds an ephemeral probe config (`build-config --probe`) containing
--      every concrete node Prism knows about — manual + all subscriptions —
--      with a loopback clash API on 127.0.0.1:9091 and nothing else, and
--      starts a second, short-lived sing-box instance from it. The running
--      (production) config stays lean: it no longer carries unreferenced
--      nodes just to make them testable.
--   2. Probes each requested tag via /proxies/<tag>/delay on the probe
--      instance, in parallel batches of CONCURRENCY uclient-fetch processes
--      (shell-forked & + wait).
--   3. Writes results into /var/etc/prism/latency.json after each batch,
--      and updates /var/etc/prism/.test-all-status with progress, so the
--      UI's poll sees results land batch by batch.
--   4. Tears the probe instance down, then sets status.running=false plus
--      tested/errors counts.
--
-- The probe instance is NOT procd-managed — it is owned by this runner,
-- which starts it, records its pid, and kills it on every exit path. The
-- "always go through procd" rule applies to the production sing-box
-- service only. A runner killed with SIGKILL can leave the instance
-- behind; the next run reclaims it via the pidfile (with a /proc/cmdline
-- identity check so a recycled pid is never killed by mistake).
--
-- The earlier implementation probed the LIVE instance's clash API, which
-- required the `include_all_nodes` flag to bloat the running config with
-- every subscription node. Before that, it called /group/<tag>/delay as a
-- single big HTTP call — sing-box's internal probe concurrency for that
-- endpoint is capped, and on a real config with ~100 unreachable nodes the
-- batch took 4+ minutes. Per-tag probes with our own concurrency knob
-- bring the wall clock down to ~one minute for the same set, with the
-- bonus that cells fill in progressively rather than all at once.

local jsonc = require "luci.jsonc"
local lib   = dofile("/usr/libexec/prism/prismlib.lua")
local read_file  = lib.read_file
local url_encode = lib.url_encode

local STATUS  = "/var/etc/prism/.test-all-status"
local LATENCY = "/var/etc/prism/latency.json"
local TMPDIR  = "/tmp/prism-latency-pending"

-- Probe instance plumbing. Host/port and config path must match
-- build-config's PROBE_CLASH_HOST / PROBE_CONFIG_PATH.
local SINGBOX       = "/usr/bin/sing-box"
local BUILD_CONFIG  = "/usr/libexec/prism/build-config"
local PROBE_HOST    = "127.0.0.1:9091"
local PROBE_CONFIG  = "/var/etc/prism/sing-box-probe.json"
local PROBE_PIDFILE = "/var/etc/prism/.sing-box-probe.pid"
local PROBE_LOG     = "/var/etc/prism/sing-box-probe.log"
local PROBE_START_TIMEOUT_S = 15   -- readiness wait for the probe instance

local CONCURRENCY      = 16            -- parallel uclient-fetch processes
local PROBE_TIMEOUT_MS = 3000          -- per-probe (clash query param)
local REQ_TIMEOUT_S    = 5             -- uclient-fetch wall clock per probe
local TEST_URL         = "http://www.gstatic.com/generate_204"

local function shell_quote(s)
	return "'" .. tostring(s):gsub("'", "'\\''") .. "'"
end

local function log_syslog(prio, msg)
	os.execute("logger -t prism -p daemon." .. prio .. " "
		.. shell_quote("test-all: " .. msg) .. " 2>/dev/null")
end

local function write_atomic(path, content)
	local dir = path:gsub("/[^/]+$", "")
	if dir ~= "" then
		os.execute("mkdir -p '" .. dir .. "' 2>/dev/null"
			.. " && chmod 0700 '" .. dir .. "' 2>/dev/null")
	end
	local tmp = path .. ".tmp"
	local f = io.open(tmp, "w")
	if not f then return false end
	f:write(content)
	f:close()
	os.execute("chmod 0600 '" .. tmp .. "' 2>/dev/null")
	return os.rename(tmp, path) ~= nil
end

local function update_status(state)
	state.updated_at = os.time()
	write_atomic(STATUS, jsonc.stringify(state))
end

-- ─── probe instance lifecycle ────────────────────────────────────────────

local probe_pid = nil

-- True when `pid` is alive AND is our probe instance — the cmdline must
-- mention the probe config path, so a pid recycled by an unrelated process
-- (or by the production sing-box) is never signalled.
local function is_probe_process(pid)
	return os.execute("[ -r /proc/" .. pid .. "/cmdline ] && tr '\\0' ' ' "
		.. "</proc/" .. pid .. "/cmdline | grep -q "
		.. shell_quote(PROBE_CONFIG)) == 0
end

-- Stop the probe instance (current run's, or a stale one left by a
-- SIGKILL'd previous runner) and remove its on-disk traces. The probe
-- config holds every node's credentials, so it never outlives the run.
local function stop_probe()
	local pid = probe_pid
	if not pid then
		local raw = read_file(PROBE_PIDFILE)
		pid = raw and tonumber(raw:match("%d+")) or nil
	end
	if pid and is_probe_process(pid) then
		os.execute("kill " .. pid .. " 2>/dev/null")
		for _ = 1, 3 do
			if os.execute("kill -0 " .. pid .. " 2>/dev/null") ~= 0 then break end
			os.execute("sleep 1")
		end
		if is_probe_process(pid) then
			os.execute("kill -9 " .. pid .. " 2>/dev/null")
		end
	end
	probe_pid = nil
	os.remove(PROBE_PIDFILE)
	os.remove(PROBE_CONFIG)
end

local function bail(msg)
	stop_probe()
	log_syslog("err", msg)
	update_status({
		running     = false,
		error       = msg,
		finished_at = os.time(),
	})
	os.exit(1)
end

-- Cooperative lock so concurrent runners cannot race on STATUS / LATENCY /
-- TMPDIR / the probe instance. Releases automatically when this process
-- exits (any signal, including SIGKILL), so a previously-killed runner does
-- not jam future runs the way a stale .test-all-status file on its own
-- would. The lock supersedes the status file as the busy gate.
local LOCK = "/var/lock/prism-test-all.lock"
os.execute("mkdir -p /var/lock 2>/dev/null")
if os.execute("lock -n " .. LOCK .. " 2>/dev/null") ~= 0 then
	os.exit(0)
end
local function release_lock() os.execute("lock -u " .. LOCK .. " 2>/dev/null") end

-- ─── start ───────────────────────────────────────────────────────────────
local started_at = os.time()
update_status({ running = true, started_at = started_at })

-- ─── decide which tags to probe ──────────────────────────────────────────
-- If luci.prism's test_all_start was called with a tag list (the per-row
-- Test button and the subscription-scoped Test all), the RPC wrote those
-- tags to TAG_FILE one per line. We use that list verbatim. Otherwise we
-- probe every concrete node in the probe config (the global Test all
-- path) — enumerated from the config itself after it is built below.
local TAG_FILE = "/var/etc/prism/.test-all-tags"
local tags = {}
local raw_tag_file = read_file(TAG_FILE)
if raw_tag_file and raw_tag_file ~= "" then
	for line in raw_tag_file:gmatch("[^\n]+") do
		if line ~= "" then tags[#tags + 1] = line end
	end
	os.remove(TAG_FILE)
end

-- ─── build the probe config and start the probe instance ────────────────
-- Reclaim any stale instance first: its pidfile (if any) points at a
-- process whose cmdline we verify before killing.
stop_probe()

local BUILD_ERR = "/var/etc/prism/.probe-build.stderr"
local build_rc = os.execute(BUILD_CONFIG .. " --probe " .. shell_quote(PROBE_CONFIG)
	.. " 2>" .. shell_quote(BUILD_ERR))
-- Forward build warnings (reserved-tag skips, corrupt sub files, …) to
-- syslog, same place the production build's stderr ends up.
os.execute("[ -s " .. shell_quote(BUILD_ERR) .. " ] && logger -t prism -p daemon.warn <"
	.. shell_quote(BUILD_ERR) .. " 2>/dev/null")
os.remove(BUILD_ERR)
if build_rc ~= 0 then
	bail("failed to build probe config")
end

local probe_handle = io.popen(SINGBOX .. " run -c " .. shell_quote(PROBE_CONFIG)
	.. " >" .. shell_quote(PROBE_LOG) .. " 2>&1 </dev/null & echo $!")
if probe_handle then
	probe_pid = tonumber((probe_handle:read("*a") or ""):match("%d+")) or nil
	probe_handle:close()
end
if not probe_pid then
	bail("cannot start probe sing-box instance")
end
write_atomic(PROBE_PIDFILE, tostring(probe_pid))

-- Readiness: the clash API answers /version as soon as sing-box is up.
-- Give up early if the process already died (config rejected, port taken)
-- rather than sitting out the full window.
local ready = false
for _ = 1, PROBE_START_TIMEOUT_S do
	local vf = io.popen("uclient-fetch -qO- --timeout=2 'http://" .. PROBE_HOST
		.. "/version' 2>/dev/null")
	local vbody = vf and (vf:read("*a") or "") or ""
	if vf then vf:close() end
	if vbody ~= "" then ready = true break end
	if os.execute("kill -0 " .. probe_pid .. " 2>/dev/null") ~= 0 then break end
	os.execute("sleep 1")
end
if not ready then
	os.execute("tail -n 5 " .. shell_quote(PROBE_LOG)
		.. " 2>/dev/null | logger -t prism -p daemon.err")
	bail("probe sing-box instance failed to start (see logread)")
end

-- ─── enumerate tags when no explicit list was given ──────────────────────
-- The probe config is the authoritative node universe: every entry in
-- `outbounds` except the builtin direct, plus every endpoint (WireGuard).
if #tags == 0 then
	local craw = read_file(PROBE_CONFIG)
	local cok, cfg = pcall(jsonc.parse, craw or "")
	if not cok or type(cfg) ~= "table" then
		bail("cannot parse probe config")
	end
	if type(cfg.outbounds) == "table" then
		for _, ob in ipairs(cfg.outbounds) do
			if type(ob) == "table" and ob.tag and ob.tag ~= "direct" then
				tags[#tags + 1] = ob.tag
			end
		end
	end
	if type(cfg.endpoints) == "table" then
		for _, ep in ipairs(cfg.endpoints) do
			if type(ep) == "table" and ep.tag then
				tags[#tags + 1] = ep.tag
			end
		end
	end
end
local total = #tags
if total == 0 then
	stop_probe()
	update_status({
		running     = false,
		started_at  = started_at,
		finished_at = os.time(),
		tested      = 0,
		errors      = 0,
	})
	os.exit(0)
end

-- ─── prepare workspace ───────────────────────────────────────────────────
os.execute("rm -rf '" .. TMPDIR .. "' 2>/dev/null")
os.execute("mkdir -p '" .. TMPDIR .. "' 2>/dev/null")

-- URL list for the shell batch script. Format: "<idx>\t<url>\n". We do the
-- URL encoding in Lua because shell-side encoding of arbitrary Unicode
-- (emoji-laden tags like 🇭🇰 HK1) is fragile across awk variants.
local urls_path = TMPDIR .. "/urls.txt"
local uf = io.open(urls_path, "w")
if not uf then bail("cannot write urls file") end
for i, tag in ipairs(tags) do
	local enc = url_encode(tag)
	local url = "http://" .. PROBE_HOST .. "/proxies/" .. enc
		.. "/delay?timeout=" .. tostring(PROBE_TIMEOUT_MS)
		.. "&url=" .. url_encode(TEST_URL)
	uf:write(string.format("%d\t%s\n", i, url))
end
uf:close()

update_status({
	running    = true,
	started_at = started_at,
	total      = total,
	done       = 0,
})

-- ─── read the existing cache so per-row results survive a batch run ─────
local cache = { results = {} }
local raw_cache = read_file(LATENCY)
if raw_cache and raw_cache ~= "" then
	local cok, cparsed = pcall(jsonc.parse, raw_cache)
	if cok and type(cparsed) == "table" then
		cache = cparsed
		if type(cache.results) ~= "table" then cache.results = {} end
	end
end

-- ─── parse one probe response, return a cache entry ─────────────────────
local function parse_result(idx)
	local entry = { tested_at = os.time() }
	local content = read_file(TMPDIR .. "/r_" .. tostring(idx))
	if not content or content == "" then
		-- uclient-fetch suppresses the body on 4xx/5xx, so empty means
		-- either the tag isn't in the probe config (404 — a node that was
		-- removed or renamed after the UI rendered) or the probe failed.
		entry.error = "timeout"
		return entry, "error"
	end
	local pok, p = pcall(jsonc.parse, content)
	if not pok or type(p) ~= "table" then
		entry.error = "invalid response"
		return entry, "error"
	end
	if type(p.delay) == "number" then
		entry.delay_ms = p.delay
		return entry, "ok"
	end
	if type(p.message) == "string" and p.message ~= "" then
		entry.error = p.message
		return entry, "error"
	end
	entry.error = "unknown response"
	return entry, "error"
end

-- ─── run probes in parallel batches ─────────────────────────────────────
-- One shell invocation per batch: spawn CONCURRENCY backgrounded
-- uclient-fetch processes from inside one shell, then `wait $PIDS` joins
-- them. The shell loop reads only this batch's slice of urls.txt via
-- awk's NR range — Lua passes the slice bounds as start/end variables.
local batch_script = TMPDIR .. "/run-batch.sh"
local tested, errors = 0, 0
local i = 1
while i <= total do
	local batch_end = math.min(i + CONCURRENCY - 1, total)
	local bs = io.open(batch_script, "w")
	if not bs then bail("cannot write batch script") end
	bs:write(string.format([[#!/bin/sh
# Slice this batch out of urls.txt into a side file so the while-read
# loop can run in the *current* shell (input redirection, not a pipe).
# A `awk | while` pipeline puts the while in a subshell — PIDS would
# vanish when the subshell exits and `wait $PIDS` would join nothing,
# leaving probes running after the script returned.
TMPDIR=%s
REQ_TIMEOUT=%d
sed -n '%d,%dp' "$TMPDIR/urls.txt" > "$TMPDIR/batch.txt"
PIDS=""
while IFS=$(printf '\t') read -r idx url; do
	uclient-fetch --timeout=$REQ_TIMEOUT -qO "$TMPDIR/r_$idx" "$url" 2>/dev/null &
	PIDS="$PIDS $!"
done < "$TMPDIR/batch.txt"
[ -n "$PIDS" ] && wait $PIDS
]], shell_quote(TMPDIR), REQ_TIMEOUT_S, i, batch_end))
	bs:close()
	os.execute("sh '" .. batch_script .. "'")

	-- Merge this batch's results into the cache and persist; the UI
	-- poll picks them up immediately so cells fill in progressively.
	for idx = i, batch_end do
		local tag = tags[idx]
		local entry, kind = parse_result(idx)
		cache.results[tag] = entry
		if kind == "ok" then tested = tested + 1
		else errors = errors + 1 end
	end
	write_atomic(LATENCY, jsonc.stringify(cache))
	update_status({
		running    = true,
		started_at = started_at,
		total      = total,
		done       = batch_end,
	})

	i = batch_end + 1
end

-- ─── done ────────────────────────────────────────────────────────────────
stop_probe()
update_status({
	running     = false,
	started_at  = started_at,
	finished_at = os.time(),
	tested      = tested,
	errors      = errors,
	total       = total,
})

-- Cleanup
os.execute("rm -rf '" .. TMPDIR .. "' 2>/dev/null")
release_lock()
