# prism watchdog — cron-driven recovery for sing-box.
#
# procd respawns a crashed sing-box, but after a burst of fast crashes it
# hits its respawn retry limit and gives up: the instance stays down while
# the TPROXY firewall rules and the dnsmasq drop-in remain in place, which
# blackholes the whole LAN — with no recovery and only procd's own syslog
# line to show for it. Run every few minutes by cron, this script detects
# the "enabled but not running" state, logs it, and re-arms the service
# with a fresh start, which hands procd a new instance and resets its
# respawn counter. A genuinely broken sing-box is thus retried at cron
# cadence rather than giving up forever.

. /lib/functions.sh

config_load prism
config_get_bool enabled global enabled 0

# Nothing to watch when the service is intentionally stopped.
[ "$enabled" = "1" ] || exit 0

# A transient pause (Status page Stop button) writes /var/run/prism.paused
# and stops the service without flipping the persistent `enabled` flag. Skip
# re-arming while paused — otherwise this watchdog would undo the user's
# action within 5 minutes. The marker is on tmpfs, so a reboot clears it
# and an enabled-but-paused service resumes naturally.
[ -e /var/run/prism.paused ] && exit 0

# procd's own view, scoped to the named `singbox` instance — mirrors
# service_running() in the rpcd handler. Must be instance-scoped: the
# prism service may also carry an `active_watch` instance, and an
# unscoped grep for `"running": true` would match the watcher's status
# and let the watchdog believe sing-box is alive when only the watcher
# is — exactly the LAN-blackhole this watchdog exists to recover from.
if ubus call service list '{"name":"prism","instance":"singbox"}' 2>/dev/null \
		| grep -q '"running": *true'; then
	exit 0
fi

logger -p daemon.err -t prism \
	"watchdog: sing-box is enabled but not running — re-arming the service"
/etc/init.d/prism start >/dev/null 2>&1
