#: htdocs/luci-static/resources/view/prism/settings.js:134
msgid ""
"How LAN traffic enters sing-box: transparently via TProxy (recommended), via "
"a TUN virtual interface, or both TProxy plus an explicit HTTP/SOCKS5 "
"listener for app clients."
msgstr ""

#: htdocs/luci-static/resources/view/prism/settings.js:137
msgid "TProxy only — transparent TCP + UDP via nftables"
msgstr ""

#: htdocs/luci-static/resources/view/prism/settings.js:138
msgid "TUN only — virtual L3 interface, sing-box manages routing"
msgstr ""

#: htdocs/luci-static/resources/view/prism/settings.js:139
msgid "TProxy + Mixed — transparent proxy and explicit HTTP/SOCKS5"
msgstr ""

#: htdocs/luci-static/resources/view/prism/settings.js:146
msgid "Proxy router traffic"
msgstr ""

#: htdocs/luci-static/resources/view/prism/settings.js:147
msgid ""
"Also send traffic originated by the router itself through sing-box (needed "
"for subscription / rule-set downloads when the source is blocked). Disable "
"only to keep admin traffic (SSH out, opkg, ntp) untunneled for debugging."
msgstr ""

